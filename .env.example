# Copy this file to .env and fill in your Supabase project's values
# (Supabase dashboard -> Project Settings -> API)
#
# If these are left blank, the site still works fully — it just runs in
# "static mode": projects/reviews come from src/lib/projectsData.js and
# src/lib/reviewsData.js, and /admin will show a "Supabase not configured"
# message.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
